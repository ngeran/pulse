/* Realtime Header Widget Styles */
/* ────────────────────────────────────────────────────────────────────────────── */

RealtimeHeader {
    height: 1;
    background: #000000;
    border-bottom: solid #3a3a3a;
    padding: 0 1;
}

RealtimeHeader > Static {
    background: #000000;
    color: #ffffff;
    text-style: bold;
    content-align: left middle;
}

/* Ensure full width */
RealtimeHeader {
    width: 1fr;
}

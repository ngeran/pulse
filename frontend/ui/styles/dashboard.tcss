/*
 * dashboard.tcss
 * ─────────────
 * Styles for the main Dashboard screen - Pure Black OLED Theme
 */

DashboardScreen {
    background: #000000;
}

DeviceManagementHeader {
    height: 3;
    width: 100%;
    background: #000000;
}

#dashboard-main {
    height: 1fr;
    width: 100%;
    background: #000000;
}

#dashboard-content {
    height: 100%;
    width: 100%;
    padding: 1;
    background: #000000;
}

DashboardFooter {
    height: 1;
    width: 100%;
    background: #1a1a1a;
}
